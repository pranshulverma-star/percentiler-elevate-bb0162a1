# Cache Vite-hashed assets aggressively (JS, CSS, images in /assets/)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML - no cache, always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Fonts
*.woff2
  Cache-Control: public, max-age=31536000, immutable
*.woff
  Cache-Control: public, max-age=31536000, immutable
